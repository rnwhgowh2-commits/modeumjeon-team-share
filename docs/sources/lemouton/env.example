# 르무통 공홈 환경변수 양식
#
# 자사몰 (Cafe24) 이라 anti-bot 우회·인증 필요 사실상 없음.
# 따라서 환경변수 필수 항목 없음. 아래는 (만약) 코드 override 가 필요할 때만.

# ─────────────────────────────────────────
# 르무통 공홈 — 모든 항목 옵셔널
# ─────────────────────────────────────────
# LEMOUTON_HEADLESS=true                    # Playwright headless 기본 true
# LEMOUTON_NAV_TIMEOUT_MS=30000             # 페이지 로드 timeout
# LEMOUTON_COLOR_CLICK_WAIT_MS=600          # 색상 클릭 후 사이즈 토글 대기

# ─────────────────────────────────────────
# 정책 룰 (현재 코드 + DB 가 처리, ENV override 없음)
# ─────────────────────────────────────────
# LEMOUTON_REVIEW_REWARD_FIXED=5000         # 리뷰 적립금 (DB compute_breakdown 가 적용)
# LEMOUTON_NPAY_RATE=0.01                   # 네이버페이 적립률
# LEMOUTON_CARD_CASHBACK_RATE=0.0273        # 현대카드 캐시백률 (auto_card_discount)
