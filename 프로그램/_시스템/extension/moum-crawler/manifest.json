{
  "manifest_version": 3,
  "name": "모음전 크롤러",
  "version": "0.7.60",
  "description": "모음전 자동화 — 로그인된 이 브라우저로 소싱처(무신사·롯데온·SSF·SSG·르무통·스마트스토어) 가격·혜택을 수집해 mou-m.com 에 전달합니다. (백그라운드 엔진=탭 닫아도 지속·새로고침해도 자동재개 + 현재 브라우저 기준 혜택 수집)",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "system.cpu",
    "system.memory",
    "alarms",
    "cookies"
  ],
  "host_permissions": [
    "https://www.mou-m.com/*",
    "https://mou-m.com/*",
    "http://54.116.196.90/*",
    "https://54.116.196.90/*",
    "http://localhost:5053/*",
    "http://127.0.0.1:5053/*",
    "http://localhost:5052/*",
    "http://127.0.0.1:5052/*",
    "https://*.musinsa.com/*",
    "https://*.lotteon.com/*",
    "https://*.ssfshop.com/*",
    "https://*.ssg.com/*",
    "https://*.lemouton.co.kr/*",
    "https://*.hmall.com/*",
    "https://*.lotteimall.com/*",
    "https://smartstore.naver.com/*",
    "https://brand.naver.com/*",
    "https://search.shopping.naver.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.mou-m.com/*",
        "https://mou-m.com/*",
        "http://54.116.196.90/*",
        "https://54.116.196.90/*",
        "http://localhost:5053/*",
        "http://127.0.0.1:5053/*",
        "http://localhost:5052/*",
        "http://127.0.0.1:5052/*"
      ],
      "js": [
        "content_mou.js"
      ],
      "run_at": "document_start"
    }
  ]
}