	<script>
		
		function resetYoutube() {
			$('.video-wrap .youtube-target').each(function(index) {
				var playerId, player;
				playerId = $(this).attr('id');
				player = YT.get(playerId);

				if($(this).parents().hasClass('gs-video')){
					$(this).siblings('.thumbnail').click(function(){

						$(this).remove();
						player.playVideo();
						player.setLoop(false);
					});
				} else {
					$(this).siblings('.thumbnail').find('.btn-play').click(function(){

						$(this).parent().remove();
						player.playVideo();
						player.setLoop(false);
					});
				}
			});
		}
		
		function onYouTubePlayerAPIReady(){
			var event;
			$('html').addClass('youtube-ready');
			event = new CustomEvent('youtubeReady');
			window.dispatchEvent(event);
			abc.namespace.front.frontOffice.setYoutubeIFrame();
			resetYoutube()
		}
		
	</script>


