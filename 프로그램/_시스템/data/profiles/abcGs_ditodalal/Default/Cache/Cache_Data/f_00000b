	// 관심 브랜드 등록을 정상적으로 완료 시
	// index : 선택한 브랜드의 노출 형태가 값으로 들어갑니다. ('핫브랜드 썸네일', '텍스트 링크')
	_outside.clickMainWishBrand = function(brandName, index) {
