	/**
	 * GRAND STAGE 메인 G-LOG_2022
	 */
	function setGSGlog(elId){
		if ($(elId).length > 0) {
			if ($(elId).find('.swiper-slide').length > 1) {
				var len = $(elId).find('.swiper-slide').length;
				var startSlideIdx, previousX, startMouseX, changeIf = false, touchEv = false, nowTime;
				var swiperGlog = new Swiper($(elId).find('.swiper-container')[0], {
					slidesPerView: 'auto',
					spaceBetween: 0,
					loop: true,
					loopedSlides:len,
					virtualTranslate: true,
					navigation: {
						prevEl: $(elId).find('.btn-gs-swiper.prev')[0],
						nextEl: $(elId).find('.btn-gs-swiper.next')[0],
					},
					on: {
						afterInit: function(){
							previousX = this.translate;

							this.$wrapperEl.css({
								'transform': 'translate3d(' + previousX + 'px, 0, 0)'
							});
						},
						touchStart: function(swiper, event){
							startMouseX = event.screenX;
							startSlideIdx = swiper.$el.find('.swiper-slide-active').index();
							touchEv = true;

							nowTime = Date.now();
						},
						touchMove: function(swiper, event){
							var moveX = previousX - (startMouseX - event.screenX);

							this.$wrapperEl.css({
								'transform': 'translate3d(' + moveX + 'px, 0, 0)'
							});
						},
						touchEnd: function(swiper, event){
							var nowPreviousX = previousX;
							setTimeout(function(){
								var endSlideIdx = swiper.$el.find('.swiper-slide-active').index();
								if ((Date.now() - nowTime) > 310 && startSlideIdx == endSlideIdx) {
									swiper.$wrapperEl.css({
										'transform': 'translate3d(' + nowPreviousX + 'px, 0, 0)'
									});
								} else {
									previousX = swiper.activeIndex * -330;
									swiper.$wrapperEl.css({
										'transform': 'translate3d(' + previousX + 'px, 0, 0)'
									});
								}
							}, 10);
						},
						transitionEnd: function(){
							if ((this.activeIndex == this.realIndex) || (this.activeIndex / 2 >= len)) {
								previousX = len * -330 + (this.realIndex * -330);
								// if (this.activeIndex == this.realIndex) {
								// 	previousX = (len * 2 - (len - this.activeIndex)) * -330;
								// } else if (this.activeIndex / 2 >= len) {
								// 	previousX = len * -330 + (this.realIndex * -330);
								// }

								this.$wrapperEl.css({
									'transform': 'translate3d(' + previousX + 'px, 0, 0)'
								});
								this.slides.removeClass('swiper-slide-active');
								this.$wrapperEl.find('.swiper-slide-duplicate-active').removeClass('swiper-slide-duplicate-active').addClass('swiper-slide-active');
								changeIf = true;
							}
						}
					}
				});

				function slideNextAction(nowX){
					var translateXVal = nowX - swiperGlog.slides[0].swiperSlideSize;

					swiperGlog.$wrapperEl.css({
						'transform': 'translate3d(' + translateXVal + 'px, 0, 0)'
					});

					previousX = translateXVal;
				}

				function slidePrevAction(nowX){
					var translateXVal = nowX + swiperGlog.slides[0].swiperSlideSize;

					swiperGlog.$wrapperEl.css({
						'transform': 'translate3d(' + translateXVal + 'px, 0, 0)'
					});

					previousX = translateXVal;
				}
				
				swiperGlog.on('activeIndexChange', function(){
					if (changeIf) {
						changeIf = false;
						return false;
					}

					if (this.previousIndex < this.activeIndex) {
						slideNextAction(previousX);
					} else if (this.previousIndex > this.activeIndex) {
						slidePrevAction(previousX);
					}
				});

				swiperOutTransition(swiperGlog);

				swiperList.push(swiperGlog);

				function activeScreenViewport(){
					//active-screen-container init
					//$('.active-screen-container .post-detail-wrapper').html($(swiperGlog.slides[swiperGlog.activeIndex]).html())
					$(elId).find('.active-screen-container .post-detail-wrapper').html($(swiperGlog.slides[swiperGlog.activeIndex]).html())

					//active-screen-container init
					var activeScreenMotionTimerId;
					var slideChangeTimerId;
					swiperGlog.on('slideChangeTransitionStart', function () {
						$('<div class="post-detail-wrapper">'+$(swiperGlog.slides[swiperGlog.activeIndex]).eq(0).html()+'</div>').appendTo($(elId).find('.active-screen-container'))
						clearTimeout(activeScreenMotionTimerId);
						activeScreenMotionTimerId = setTimeout(function(){
							$(elId).find('.active-screen-container').addClass('init');
							setTimeout(function(){
								$(elId).find('.active-screen-container').removeClass('init');
								$(elId).find('.active-screen-container .post-detail-wrapper').last().siblings().each(function(){
									$(this).remove();
								})
							},200)
						},20)
						
					})
				};
				activeScreenViewport();
				

				/*$(window).resize(function(){
					swiperGlog.destroy();
					swiperGlog = new Swiper('.gs-glog .swiper-container', {
						slidesPerView: 'auto',
						spaceBetween: 0,
						loop: true,
						loopedSlides:4,
						slideToClickedSlide: true,
						navigation: {
							prevEl: '.gs-glog .btn-gs-swiper.prev',
							nextEl: '.gs-glog .btn-gs-swiper.next',
						},
					});
					activeScreenViewport();

					swiperList.push(swiperGlog);
				})*/
			} else {
				$(elId).find('.swiper-control').hide();
			}
		}
	}

	/**
