	/**
	 * GRAND STAGE 메인 배너 스와이퍼 22-05-23
	 */
	function setGSMainBanner(elId) {
		$(elId).find('.fraction .total').text(abc.namespace.front.frontOffice.setPrependZero($(elId).find('.swiper-slide').length));
		if ($(elId).find('.swiper-container').length > 0) {
			var videoInfo = {};
			var container = $('.gs-main-banner');
			var activeVideo = container.find('video');
			// var videoWrapper = $('#introVideo');
			var videoWrapper = container.find('.video-swiper');
			var ytVideo = container.find('.youtube-target-main');
			var isVideo = (activeVideo.length) ? true : false;
			var isytVideo = (ytVideo.length) ? true : false;

			// 배너 이미지 롤링 스와이퍼 22-05-17 비디오 영역 분리 관련 수정됨
			var swiperMainBanner = new Swiper($(elId).find('.swiper-container')[0], {
				init: false,
				effect : 'fade',
				slidesPerView: 1,
				spaceBetween: 0,
				speed: 500,
				loop: true,
				centeredSlides: true,
				allowTouchMove: false,
				navigation: {
					prevEl: $(elId).find('.swiper-navigation .btn-gs-swiper.prev')[0],
					nextEl: $(elId).find('.swiper-navigation .btn-gs-swiper.next')[0],
				},
				pagination: {
					el: $(elId).find(".swiper-pagination.progressbar")[0],
					type: "progressbar",
				},
				autoplay: {
					delay: 5000,
					disableOnInteraction: false,
				}, 
				/*
				loopedSlides: $('.gs-main-banner-box .swiper-slide').length * 2,
				thumbs: {
					swiper: swiperMainControl,
				}, */
			});
			
			swiperList.push(swiperMainBanner);

			$(elId).find('.fraction .current').text(abc.namespace.front.frontOffice.setPrependZero(swiperMainBanner.realIndex + 1));

			$(elId).find('.swiper-navigation .btn-toggle').click(function(){
				if($(this).hasClass('pause')){
					swiperMainBanner.autoplay.stop();
					$(this).hide().siblings('.play').show();
				} else if($(this).hasClass('play')) {
					swiperMainBanner.autoplay.start();
					$(this).hide().siblings('.pause').show()
				}
			});

			var YTReady = false;
			function videoControl(){
				var videoId, player, iFrameId, videoWidth, videoHeight;

				//영상 클릭시
				$('.video-swiper').click(function(){
					if($(this).data('href') && $(this).data('blank')){
						window.open($(this).data('href'));
					} else if($(this).data('href') && !$(this).data('blank')){
						window.location.href = $(this).data('href');
					}
				})

				if (isytVideo) {
					ytVideo = container.find('.youtube-target-main');
					
					$(window).one('youtubeReady', function () {
						ytVideo.each(function(ytIndex){
				
							videoId = getVideoId(ytVideo.data('videoUrl'));
							videoWidth = ytVideo.data('videoWidth') ? ytVideo.data('videoWidth') : '100%';
							videoHeight = ytVideo.data('videoHeight') ? ytVideo.data('videoHeight') : '56.25%';
				
							if (videoWidth === undefined || videoHeight === undefined) {
								throw Error('유튜브 비디오는 넓이값을 가져야합니다.');
							}
				
							iFrameId = 'youtubeFrame' + $('iframe').length;
							ytVideo.attr('id', iFrameId);
							player = new YT.Player(iFrameId, {
								width: videoWidth,
								height: videoHeight,
								videoId: videoId, // 200205 고화질 섬네일 출력 위해 주석 해제
								host: 'https://www.youtube.com',
								playerVars: {
									'playlist': videoId,
									'autoplay': 1,
									'controls': 0,
									'showinfo': 0,
									'rel': 0,
									'disablekb': 1,
									'loop': 0,
									'modestbranding': 1,
									'origin': location.href,
									'mute': true
								},
								// s : 190828 이벤트 추가
								events: {
									'onReady': function (event) {
										var iFrameId = event.target.i.id;
										var playerTarget;
										playerTarget = $('#' + iFrameId);
										playerTarget.data('player', player);
										
										if (ytIndex + 1 == ytVideo.length) {
											YTReady = true;
										}
									},
									'onStateChange': function (event){
										playerState = event.data == YT.PlayerState.ENDED ? '종료됨' :
												event.data == YT.PlayerState.PLAYING ? '재생 중' :
												event.data == YT.PlayerState.PAUSED ? '일시중지 됨' :
												event.data == YT.PlayerState.BUFFERING ? '버퍼링 중' :
												event.data == YT.PlayerState.CUED ? '재생준비 완료됨' :
												event.data == -1 ? '시작되지 않음' : '예외';
										
										if (event.data == YT.PlayerState.ENDED) {
											if ($(elId).find('.pause').css('display') == 'block') {
												//videoWrapper.removeClass('show');
												swiperMainBanner.autoplay.start();
											} else {
												swiperMainBanner.autoplay.stop();	
											}
											//$('#'+iFrameId).parents('.swiper-slide').addClass("video-ended");
										}else if(event.data == YT.PlayerState.PLAYING){
											swiperMainBanner.autoplay.stop();
											//videoWrapper.addClass('show');
										}
									}
								}
								// e : 190828 이벤트 추가
							});

							function getVideoId(url) {
								var regExp = /^.*((youtu.be\/)|(v\/)|(\/u\/\w\/)|(embed\/)|(watch\?))\??v?=?([^#\&\?]*).*/;
								var match = url.match(regExp);
				
								if (match && match[7].length === 11) {
									return match[7];
								} else {
									return 'error';
								}
							}
						});
						return {
							video : videoWrapper,
							player : iFrameId,
							ready : YTReady
						}
					});
				}else if(isVideo){
					activeVideo.get(0).addEventListener("ended", function(){
						if ($(elId).find('.pause').css('display') == 'block') {
							//videoWrapper.removeClass('show');
							swiperMainBanner.autoplay.start();
							swiperMainBanner.slideNext();
						}
						//swiperMainBanner.slides[swiperMainBanner.activeIndex].classList.add('transition');
						
					});
					activeVideo.get(0).addEventListener("playing", function(){
						//videoWrapper.addClass('show');
						swiperMainBanner.autoplay.stop();
						//swiperMainBanner.slides[swiperMainBanner.activeIndex].classList.remove('transition');
					})
					
					return {
						video : videoWrapper,
						player : activeVideo.get(0)
					}
				}
			}
			

			//최초 한번 실행됨
			var videoReadyChkInterval;
			swiperMainBanner.on('init', function () {
				
				swiperMainBanner.autoplay.stop();

				if(isytVideo){
					videoControl();
					// videoReadyChkInterval = setInterval(function(){
					// 	videoInfo = videoControl();					
					// 	if(videoInfo.ready){
					// 		clearInterval(videoReadyChkInterval);
					// 	}
					// }, 100);	
				}else if(isVideo){
					videoInfo = videoControl();
				}
				

				swiperMainBanner.on('slideChangeTransitionStart', function () {
					//첫번째 인덱스일경우 영상이 존재할경우 재생
					var startIdx = 1;
					var endIdx = swiperMainBanner.slides.length-1;

					if(!swiperMainBanner.params.loop){
						startIdx = 0;
						endIdx = 0;
					}
					//if(swiperMainBanner.activeIndex == endIdx || swiperMainBanner.activeIndex == startIdx) {
					if ($(swiperMainBanner.slides[swiperMainBanner.activeIndex]).find('.video-swiper').length > 0) {
						if(isytVideo){
							$(elId).find('.video-swiper iframe').each(function(){
								if($(this).data('player') != undefined) {
									$(this).data('player').playVideo();
								}
							});
						}else if(isVideo){
							$(elId).find('video').each(function(){
								this.currentTime = 0;
								this.play();
							});
						}
					} else {
						if(isytVideo){
							$(elId).find('.video-swiper iframe').each(function(){
								if($(this).data('player') != undefined){
									$(this).data('player').stopVideo();
								}
							});
						}else if(isVideo){
							$(elId).find('video').each(function(){
								this.pause();
							});
						}

						if ($(elId).find('.pause').css('display') == 'block') {
							swiperMainBanner.autoplay.start();
						} else {
							swiperMainBanner.autoplay.stop();
						}
					}
					//}
				})

				swiperMainBanner.on('slideChangeTransitionEnd', function () {
					var startIdx = 1;
					var endIdx = swiperMainBanner.slides.length-1;

					if(!swiperMainBanner.params.loop){
						startIdx = 0;
						endIdx = 0;
					}
					//첫번째 슬라이드 일경우
					if(videoWrapper.length){
						if(swiperMainBanner.activeIndex == endIdx || swiperMainBanner.activeIndex == startIdx) {
							
						}else{
							//css모션처리를 위한 클래스 부여
							swiperMainBanner.slides[swiperMainBanner.activeIndex].classList.add('transition');
							$(swiperMainBanner.slides[swiperMainBanner.activeIndex]).siblings().removeClass('transition');
						}
					}else{
						swiperMainBanner.slides[swiperMainBanner.activeIndex].classList.add('transition');
						$(swiperMainBanner.slides[swiperMainBanner.activeIndex]).siblings().removeClass('transition');
					}

				});

				if(!videoWrapper.length){
					swiperMainBanner.autoplay.start();
					swiperMainBanner.slides[swiperMainBanner.activeIndex].classList.add('transition');
				}
			});

			swiperMainBanner.init();

			/* 
			swiperMainBanner.on('slideChange', function() {
				setGNBTypeByActiveBanner(swiperMainBanner);
			});
			*/

			swiperMainBanner.on('slideChange', function() {
				$('.gs-main-banner .fraction .current').text(abc.namespace.front.frontOffice.setPrependZero(swiperMainBanner.realIndex + 1));
			});
		}
	}

	/**
	 * 배너 타입별 GNB 메뉴 텍스트 색상 변경(type-w 흰색, type-b 검은색)
	 * @param swiper
	 */
	function setGNBTypeByActiveBanner(swiper) {
		var bannerType, gnbWrap, gnbClassList;

		gnbWrap = $('.header-wrap .gnb-wrap');
		bannerType = $(swiper.slides[swiper.activeIndex]).data('bannerType');
		gnbClassList = gnbWrap.attr('class').split(' ');
		$.each(gnbClassList, function(index) {
			if (this.search('type-') !== -1) {
				gnbWrap.removeClass(this.toString());
			}
		});
		if (bannerType !== undefined && bannerType !== '') {
			gnbWrap.addClass('type-' + bannerType.toLowerCase());
		}
	}

