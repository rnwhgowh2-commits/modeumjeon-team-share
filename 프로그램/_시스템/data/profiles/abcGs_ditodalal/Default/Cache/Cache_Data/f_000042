	/**
	 * GRAND STAGE 메인 전용 Marquee 코드 추가
	 */
	function setGSBannerMarquee(selector) {
		selector = selector ? selector : '.gs-loop-banner';

		if ($(selector).length > 0) {
			$(selector).each(function(index) {
				var wrap, sensor;
				wrap = $(this);

				fillMarqueeWrapper(wrap);

				sensor = new ResizeSensor(this, function () {
					wrap.removeClass('initialized');
					fillMarqueeWrapper(wrap);
				});
			});
		}

		// 입력된 텍스트의 길이가 wrap의 넓이보다 작을때 복사본 생성
		function fillMarqueeWrapper(wrap) {
			var wrapperWidth, marquee, marqueeText, dupLink, marqueeTextCnt, duplicateCnt, duration, weight;
			wrapperWidth = wrap.outerWidth();
			marquee = wrap.find('.loop-group');
			marqueeText = wrap.find('.loop-group .text-loop');
			duplicateCnt = Math.max(Math.ceil(wrapperWidth * 2 / marquee.outerWidth()), 2);
			weight = 2;

			duration = Math.floor(marqueeText.outerWidth() / wrapperWidth * 1000) / 100 * weight;
			// console4(duration);
			marquee.empty();
			marquee.append(marqueeText);
			marqueeTextCnt = 1;

			while (marqueeTextCnt < duplicateCnt) {
				dupLink = marqueeText[0].cloneNode(true);
				dupLink.setAttribute('aria-hidden', true);
				wrap.find('.loop-group').append(dupLink);
				marqueeTextCnt++;
			}

			marqueeText = wrap.find('.loop-group .text-loop');
			marqueeText.each(function(index) {
				$(this).css('animation-duration', duration + 's');
				// $(this).css('animation-duration', (30 * duration / 10) + 's');
			});

			wrap.addClass('initialized');
		}
	}


	/**
	 * GRAND STAGE 메인 전용 clip
	 */
	function setGSClip(elId) {
		var listItems = document.querySelectorAll(`${elId} .list-item`);

		listItems.forEach((item) => {
			var videoBox = item.querySelector('.video-box');
			if (videoBox) {
				var video = videoBox.querySelector('video');
				if (video) {
					// hover 시작 시
					videoBox.addEventListener('mouseenter', () => {
						video.currentTime = 0;
						video.play();
					});

					// hover 종료 시
					videoBox.addEventListener('mouseleave', () => {
						video.pause();
						video.currentTime = 0;
					});
				}
			}
		});
	}


	/**
	 * GRAND STAGE 메인 전용 상품 슬라이드 (md, 신상품)
	 */
	function setGSProdSlide(elId) {
		if ($(elId).length > 0 && $(elId).hasClass('gs-prod-slide')) {
			if ($(elId).find('.slide-cont .swiper-slide').length > 1) {
				var swiperProdSlideTitle = null;
				var swiperProdSlide = null;

				$(elId).find('.slide-title .swiper-container').each(function(idx) {
					var totalSlideWidth = 0;
					var slideCount = $(this).find('.swiper-slide').length;
					$(this).find('.swiper-slide').each(function() {
						totalSlideWidth += $(this).outerWidth();
					});
					var containerWidth = $(this).outerWidth() - (slideCount * 26);
					var loopEnabled = totalSlideWidth > containerWidth;

					swiperProdSlideTitle = new Swiper(this, {
						slidesPerView: 'auto',
						spaceBetween: 26,
						loop: loopEnabled,  // 조건에 따라 루프 활성화
						resistance: true,
						resistanceRatio: 0,
						watchSlidesVisibility: true,
						watchSlidesProgress: true,
					});
					swiperList.push(swiperProdSlideTitle);
				});

				$(elId).find('.slide-cont .swiper-container').each(function(idx) {
					swiperProdSlide = new Swiper(this, {
						slidesPerView: 1,
						spaceBetween: 40,
						observer: true,
						observeParents: true,
						loop: true,
						resistance: true,
						resistanceRatio: 0,
						watchSlidesVisibility: true,
						watchSlidesProgress: true,
						// effect:'fade',
						navigation: {
							prevEl: $(this).parent().find('.btn-gs-swiper.prev')[0],
							nextEl: $(this).parent().find('.btn-gs-swiper.next')[0],
						},
						thumbs: {
							swiper: swiperProdSlideTitle, // 썸네일 슬라이드와 연결
						},
						on: {
							slideChange: function () {
								let activeIndex = this.realIndex;
								let thumbnailActiveIndex = swiperProdSlideTitle.realIndex;
								let visibleSlides = swiperProdSlideTitle.visibleSlidesIndexes;

								// 마지막 슬라이드에서 첫 번째 슬라이드
								if (this.isEnd && activeIndex === 0) {
									setTimeout(() => {
										swiperProdSlideTitle.slideToLoop(0, 120);
									}, 30);
								}
								// 첫 번째 슬라이드에서 마지막 슬라이드
								else if (this.isBeginning && activeIndex === this.slides.length - 1) {
									swiperProdSlideTitle.slideToLoop(swiperProdSlideTitle.slides.length - 1, 120);
								}
								// 썸네일이 보이지 않으면 썸네일을 해당 인덱스로 이동
								else if (!visibleSlides.includes(activeIndex)) {
									swiperProdSlideTitle.slideToLoop(activeIndex, 120);
								}
							}

						},
					});
					swiperList.push(swiperProdSlide);
				});
			} else {
				$(elId).find('.swiper-control').hide();
			}
		}
	}




