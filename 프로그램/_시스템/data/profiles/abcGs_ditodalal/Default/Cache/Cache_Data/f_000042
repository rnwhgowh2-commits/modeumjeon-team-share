	function setGSEvent(){
		/* MARQUEE */
		if($('.loop-group').length > 0){
			$('.video-wrap .loop-group').each(function(){
				var loopWrapper = $(this);
				var itemWidht = loopWrapper.find('.text-loop span').outerWidth(true);
				var itemNum = Math.ceil(loopWrapper.width() / itemWidht);
				var _clone = '<span>New Video</span>';

				for(i = 0; i <= itemNum; i++){
					loopWrapper.find('.text-loop').append(_clone);
				}
			});
		}

		/* VIDEO MOVE BUTTON */
		if($('.gs-video').length > 0){
			var btnMoveArea = $('.gs-video').find('.video-wrap');
			//init
			btnMoveArea.addClass('ended');
			
			//for cursor
			btnMoveArea.mouseenter(function(){
				btnMoveArea.addClass('cursor-view');
			})
			btnMoveArea.mouseleave(function(){
				btnMoveArea.removeClass('cursor-view');
			})
			btnMoveArea.mousemove(function(e){
				var isTop = e.pageY - btnMoveArea.offset().top;
				var isLeft = e.pageX - btnMoveArea.offset().left;
				if(isTop < 110 || isTop > 710){
					isTop = -200;
				}
				$(this).find('.btn-play').css({'top':isTop, 'left':isLeft})
			});
			var video = $('.gs-video').find('video');
			var ytVideo = $('.gs-video').find('.youtube-target-video');

			//비디오 영상이라면
			if(video.length){
				video.get(0).addEventListener("ended", function(){
					btnMoveArea.addClass('ended');
					btnMoveArea.removeClass('paused');
				});
			}
			//유튜브 영상이라면
			if(ytVideo.length){
				function getVideoId(url) {
					var regExp = /^.*((youtu.be\/)|(v\/)|(\/u\/\w\/)|(embed\/)|(watch\?))\??v?=?([^#\&\?]*).*/;
					var match = url.match(regExp);
	
					if (match && match[7].length === 11) {
						return match[7];
					} else {
						return 'error';
					}
				}
				$(window).one('youtubeReady', function () {
					ytVideo.each(function(){
						var player;
						var ytVideo = $(this);
						var videoId = getVideoId(ytVideo.data('videoUrl'));
						var videoWidth = ytVideo.data('videoWidth') ? ytVideo.data('videoWidth') : '100%';
						var videoHeight = ytVideo.data('videoHeight') ? ytVideo.data('videoHeight') : '56.25%';
		
						if (videoWidth === undefined || videoHeight === undefined) {
							throw Error('유튜브 비디오는 넓이값을 가져야합니다.');
						}
						iFrameId = 'youtubeFrame' + $('iframe').length;
						
						ytVideo.attr('id', iFrameId);
						player = new YT.Player(iFrameId, {
							width: videoWidth,
							height: videoHeight,
							videoId: videoId, // 200205 고화질 섬네일 출력 위해 주석 해제
							host: 'https://www.youtube.com',
							playerVars: {
								'playlist': videoId,
								'autoplay': 1,
								'controls': 0,
								'showinfo': 0,
								'rel': 0,
								'disablekb': 1,
								'loop': 0,
								'modestbranding': 0,
								'origin': location.href,
								'mute': true
							},
							// s : 190828 이벤트 추가
							events: {
								'onReady': function (event) {
									var iFrameId = event.target.i.id;
									var playerTarget;
									playerTarget = $('#' + iFrameId);
									playerTarget.data('player', player);
									playerTarget.data('player').pauseVideo();

								},
								'onStateChange': function (event){
									var iFrameId = event.target.i.id;
									var playerState = event.data == YT.PlayerState.ENDED ? '종료됨' :
											event.data == YT.PlayerState.PLAYING ? '재생 중' :
											event.data == YT.PlayerState.PAUSED ? '일시중지 됨' :
											event.data == YT.PlayerState.BUFFERING ? '버퍼링 중' :
											event.data == YT.PlayerState.CUED ? '재생준비 완료됨' :
											event.data == -1 ? '시작되지 않음' : '예외';
									
									if (event.data == YT.PlayerState.ENDED) {
										btnMoveArea.addClass('ended');
										btnMoveArea.removeClass('paused');
									}
								}
							}
							// e : 190828 이벤트 추가
						});
					})
				})
			}

			btnMoveArea.click(function(){
				var me = $(this);
				
				if(video.length){
					if(!btnMoveArea.is('.paused')){
						btnMoveArea.removeClass('ended');
						btnMoveArea.addClass('paused');
						video.get(0).play();
					}else{
						btnMoveArea.removeClass('paused');
						video.get(0).pause();
					}
					
					
				}
				if(ytVideo.length){
					var player = $('.gs-video').find('.youtube-target-video').data('player');
					if(player.getPlayerState() == 1){
						player.pauseVideo();
						btnMoveArea.removeClass('paused');
					}else{
						btnMoveArea.removeClass('ended');
						btnMoveArea.addClass('paused');
						player.playVideo();
					}
				}
			})
			

			/*
