	/**
	 * GRAND STAGE 메인 ONLY/EXCLUSIVE_2022
	 */
	function setGSOnly(elId){
		if ($(elId).length > 0 && $(elId).hasClass('gs-only')) {
			$(elId).find('.swiper-group').each(function(idx){
				if ($(this).find('.swiper-slide').length > 3) {
					var swiperOnly = new Swiper($(this).find('.swiper-container')[0], {
						slidesPerView: 'auto',
						spaceBetween: 0,
						observer: true,
						observeParents: true,
						// centeredSlides: true,
						navigation: {
							prevEl: $(this).find('.btn-gs-swiper.prev')[0],
							nextEl: $(this).find('.btn-gs-swiper.next')[0],
						},
						pagination: {
							el: $(this).find('.swiper-pagination')[0],
							type: "progressbar",
						},
					});
			
					swiperList.push(swiperOnly);
				} else {
					$(this).find('.swiper-control').hide();
				}
			})
			
		}
	}

	/*
		swiper slide의  active상태에서 해제되는 순간의 모션 구현을 위한
		클래스 부여 함수
	 */
	function swiperOutTransition(swiperObj){
		swiperObj.on('slideChangeTransitionStart', function () {
			swiperObj.slides[swiperObj.previousIndex].classList.add('transition');
		})
		swiperObj.on('slideChangeTransitionEnd', function () {
			$(swiperObj.slides).removeClass('transition');
		})
	}
	
