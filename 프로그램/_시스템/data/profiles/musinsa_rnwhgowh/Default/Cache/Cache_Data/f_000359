//recivemessage
window.addEventListener("message", snap_spm_receiveMessage, false);

function snap_spm_receiveMessage(event) {

    // if (event.origin.indexOf('snapvi') != -1 || event.origin.indexOf('snapfit') != -1) {
    var data = event.data;
    // if (!data || !data.match("/^{.*}$/g")) {
    //     return;
    // }
    if (!data) {
        return;
    }

    var values = '';

    try {
        values = JSON.parse(data);
    } catch (e) {
        return false;
        /*
        if (typeof data === 'object') {
            values = data;
        } else {
            console.log(e);
        }
        */
    }

    var params = values.params;

    if (values.e == 'snap_sf_post_to_resultviewmessage') {
        var data = params['data'];
        var func = values.func
        if (func == 'set_and_show_similaryresult') {
            set_and_show_similaryresult(data);
        } else if (func == 'resultsimilarusersize') {
            data['resultby'] = 'post_message';
            resultsimilarusersize(data);
        } else if (func == 'show_result_histroy') {
            spm_banner_logic_object_Instance.banner_logic_object.show_result_histroy(data);
        }
    } else if (values.e == 'snap_show_directPush') {
        //console.log(params.data.url);
        location.replace(params.data.url);
    }
}

receive_from_server_post_result = function (data, frameid) {
    if (data) {
        sfspmSubmoduleInstance.post_show_result(data, frameid);
    }
}


