	/**
	 * ABC-MART 메인 구좌 추가
	 * 이벤트/혜택 (10021), 인앱메뉴 (10020) , 행사띠배너 (10019) , 프로모션배너 (10022)
	 */
	_mainAbc.mainCornerLoad = function(cornerSeq, cornerTypeCode, viewName){
		var params = abc.param.getParams();
		if(cornerTypeCode.indexOf("_") > 0) {
			cornerTypeCode = cornerTypeCode.split("_")[0];
		}
		$.ajax({
			dataType : "html",
			type :"POST",
			url : "/get-abcmain-corner-detail",
			data : {
						"cornerSeq"	: cornerSeq
					  , "cornerTypeCode" : cornerTypeCode
					  , "mainViewName" : viewName
					  , 'previewType' : params.previewType
					  , 'previewDt' : params.previewDate
				   }
		}).done(function(data){
			var objSection = "#" + viewName + cornerSeq;

			$(objSection).append(data);
			var deleteFlag = $(objSection).find('input[name=deleteFlag]').val();
			if(deleteFlag == "true"){
				$(objSection).remove();
			}else{
				setTimeout(function () {
					_mainAbc.mainLoadAfter(cornerTypeCode, objSection);
				}, 100);
			}
		}).fail(function(jqXHR, textStatus, errorThrown) {

		});
	}

	_mainAbc.mainLoadAfter = function(cornerTypeCode, objSection){
		switch (cornerTypeCode) {
		case "10021": // 이벤트/혜택
			break;
		case "10020": // 인앰아이콘
			setAbcInApp(objSection);
			break;
		case "10019": // 행사띠배너
			setAbcEventBanner(objSection);
			break;
		case "10022": // 프로모션
			setAbcPromotion(objSection);
			break;
		case "10023": // 핫딜
