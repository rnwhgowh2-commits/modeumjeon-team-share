	/**
	 * trend on 영역에 유트브 유혛의 동영상 재생을 위한 실행 함수1
	 * 유튜브 유형의 영역의 loop로 관련된 값들을 추출 및 세팅
	 */
	function setTrendOnYoutube(){
		let trendOnPlayerObj 	= 'trendOnPlayerArea_'; // trend on 유튜브 영역의 id값[like loop 검색 타겟]
		let interval			= 800; // 유튜브 영역 호출 interval 시간(n*interval 만큼 증가)
		let videoUrl 			= "";  // 재생할 유튜브 주소
		let regex 				= /^(?:(?:https|http):\/\/)?(?:www\.)?(?:youtube\.com|youtu\.be).*?(?:\/|v\/|u\/|embed\/|shorts\/|watch\?v=|(?<username>user\/))(?<id>[\w\-]{11})(?:\?|&|$)/; // 유튜브 id 추출 정규식
		let urlResult 			= null; // 최종 유튜브 url

		$("div[id^='" + trendOnPlayerObj + "']").each(function (i, v) {
			interval += interval;
			videoUrl  = $(this).data('videoUrl');
			urlResult = videoUrl.match(regex);

			if(urlResult && urlResult[2]) {
				videoUrl = urlResult[2];
			}
			getYoutubeTimeOut(v.id, videoUrl, interval);
		});
	}

	/**
	 * trend on 영역에 유트브 유혛의 동영상 재생을 위한 실행 함수2
	 * 동영상 타겟 객체와 url 등의 파라미터로 setTimeout 함수를 호출
	 * loop에서 실행 시 제대로 값 전달이 되지 않거나 동영상을 제대로 재생시키지 못함(2개이상 동영상 재생 오류 이슈) 따로 호출 함수에서 setTimeout으로 필수 실행 함수[onYouTubeIframeAPIReadyTrendOn]를 호출해준다.
	 */
	function getYoutubeTimeOut(obj, url, interval) {
		setTimeout(() => {
			onYouTubeIframeAPIReadyTrendOn(obj, url);
		}, interval);
	}

	/**
	 * trend on 영역에 유트브 유혛의 동영상 재생을 위한 실행 함수3
	 * Youtube API 로드
	 * https://developers.google.com/youtube/iframe_api_reference 참고
	 */
	let playerArea;
	function onYouTubeIframeAPIReadyTrendOn(obj, url) {
		playerArea = new YT.Player(obj, {
			videoId    : obj, //youtube 영상ID
			playerVars : {
				'autoplay': 1,
				'rel'     : 0,
				'showinfo': 0,
				'modestbranding': 1,
				'playsinline'   : 1,
				'rel'     : 0,
				'controls': 0,
				'color'   :'white',
				'loop'    : 1,
				'playlist': url,
			},
			events : {
				'onReady': onPlayerReadyArea,
			}
		});
	}

	/**
	 * trend on 영역에 유트브 유혛의 동영상 재생을 위한 실행 함수4
	 * onYouTubeIframeAPIReadyTrendOn에서 지정된 함수 호출
	 * 동영상 재생 및 무음 처리
	 */
	function onPlayerReadyArea(event) {
		playerArea.mute();
		playerArea.playVideo();
	}
