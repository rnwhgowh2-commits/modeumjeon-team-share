	/**
	 *  메인 MD 추천/only
	 */
	var swiperList = [];
	function setAbcMdRecom(elId) {
		if ($(elId).length > 0 && $(elId).hasClass('abc-md-only')) {
			$(elId).find('.slide-title .swiper-container').each(function () {
				var totalSlideWidth = 0;
				var slideCount = $(this).find('.swiper-slide').length;
				$(this).find('.swiper-slide').each(function () {
					totalSlideWidth += $(this).outerWidth();
				});
				var containerWidth = $(this).outerWidth() - (slideCount * 36);
				var isOverflow = totalSlideWidth > containerWidth;

				var swiperProdSlideTitle = new Swiper(this, {
					slidesPerView: 'auto',
					// spaceBetween: 36,
					allowTouchMove: false,
					resistance: true,
					resistanceRatio: 0,
					watchSlidesVisibility: true,
					watchSlidesProgress: true,
					speed: 500,
				});

				$(swiperProdSlideTitle.slides).removeClass('swiper-slide-thumb-active');
				$(swiperProdSlideTitle.slides[0]).addClass('swiper-slide-thumb-active');

				swiperProdSlideTitle.on('tap', function () {
					var swiper = this;
					var clickedIndex = swiper.clickedIndex;
					if (clickedIndex == null) return;
					var clickedSlide = swiper.slides[clickedIndex];

					// active 클래스 토글
					$(swiper.slides).removeClass('swiper-slide-thumb-active');
					$(clickedSlide).addClass('swiper-slide-thumb-active');

					// isOverflow일 때만 가운데 정렬
					if (isOverflow) {
						var containerWidth = swiper.width;
						var slideOffset = clickedSlide.offsetLeft;
						var slideWidth = clickedSlide.offsetWidth;
						var slideCenter = slideOffset + slideWidth / 2;
						var containerCenter = containerWidth / 2;
						var targetTranslate = containerCenter - slideCenter;
						var minTranslate = swiper.maxTranslate();
						var maxTranslate = swiper.minTranslate();
						targetTranslate = Math.max(minTranslate, Math.min(targetTranslate, maxTranslate));

						swiper.setTransition(500);
						swiper.setTranslate(targetTranslate);
						swiper.updateProgress();
						swiper.updateActiveIndex(clickedIndex);
						swiper.updateSlidesClasses();
					}
				});
			});
		}
		
		_mainAbc.setProductIconSize(elId);	// 상품아이콘 사이즈 설정

		$(elId).find(".slide-title li").eq(0).addClass("swiper-slide-thumb-active");
		$(elId).find(".slide-title li").on("click",function(){ // 변동훈M 추가 함수 start

			$(elId).find(".slide-title li").each(function(){
				$(this).removeClass("swiper-slide-thumb-active");
			});
            $(this).addClass("swiper-slide-thumb-active");
			$.ajax({
				dataType : "html",
				type :"POST",
				url : "/get-abcmain-corner-detail-prdt",
				data : {
					"cornerSeq"	: $(this).data("cornerSeq")
					, "cornerSetSeq" : $(this).data("cornerSetSeq")
				}
			}).done(function(data){
                $(elId).find("#foRecomPrdt0").empty();
				$(elId).find("#foRecomPrdt0").append(data);

				var $badges = $(elId).find('.prod-badge-img');

				$badges.each(function () {
					var $container = $(this);
					var $img = $container.find('.badge-img');

					if (!$img.length) return;

					var img = $img[0];
					if (img.complete && img.naturalWidth > 0) {
						var imgWidth = img.naturalWidth;
						$container.css('width', (imgWidth / 2) * 20 / 30);
					} else {
						img.onload = function () {
							var imgWidth = img.naturalWidth;
							$container.css('width', (imgWidth / 2) * 20 / 30);
						};
					}
				});

                //console.log(data);
			}).fail(function(jqXHR, textStatus, errorThrown) {

			});
		}); // 변동훈M 추가 함수 end
    }
	
