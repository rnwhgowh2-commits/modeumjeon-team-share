			_HTML += '		<span class="ui-chk type-text">';
			_HTML += '			<input id="'+belong+'chkCategoryAll'+chnnlNo+'" name="categoryAll" type="checkbox">';
			_HTML += '			<label for="'+belong+'chkCategoryAll'+chnnlNo+'">전체</label>';
			_HTML += '		</span>';
			_HTML += '	</li>';

