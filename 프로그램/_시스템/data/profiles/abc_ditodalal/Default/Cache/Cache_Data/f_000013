			if(data[type].COLOR_LIST.length == 0){
				$("#colorFilterContentLi").hide();
			}else{
				$("#colorFilterContentLi").show();
			}

			// price range
			if (data[type].PRICE_LIST.length > 0) {
				if(!abc.text.allNull(params.price) && belong =='i' && isCheck == "Y"){
