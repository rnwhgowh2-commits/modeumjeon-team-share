	/**
	 * jquery 객체 생성 시 오류를 발생시키는 문자에 대한 처리
	 * ( ) [ ] ~ . /
	 */
	_search.getReplaceExp = function(obj) {
		if(obj == null){
			return "";
		}else{
			obj = obj.replace(/\(/gi,"\\(").replace(/\)/gi,"\\)").replace(/\[/gi,"\\[").replace(/\]/gi,"\\]").replace(/\~/gi,"\\~").replace(/ /gi,"").replace(/\./gi,"\\.");
			return obj;
		}
	} // end _search.getReplaceExp


