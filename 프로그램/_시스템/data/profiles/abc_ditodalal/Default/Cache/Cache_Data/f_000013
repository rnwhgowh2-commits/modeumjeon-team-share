			if($('#iChkChannel'+chnnlNo).length > 0){
				$("[id^=iChkChannel]").removeClass("active");
				$("#iChkChannel"+chnnlNo).addClass("active");
				if(chnnlNo != '10000'){
					$("#iChkChannel"+chnnlNo).addClass("expanded");
