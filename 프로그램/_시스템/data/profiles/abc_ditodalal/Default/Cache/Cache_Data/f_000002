				url : '/product/info',
				data : { "prdtNo" : prdtNo, "xramdom" : Math.random()}
			})
			.done(function(data){

				switch (warehousingYn) {
				case '입고':
					$('#re-warehousing-form #wrhs-alert-type').val('Y');
					abc.biz.product.re.warehousing.alert.setIntrstPrdtOptnNo(data.productOption);
