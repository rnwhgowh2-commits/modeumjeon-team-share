				}
				//옵션 노출 관련 추가  20211215 S 재입고 알림 옵션명 변경 노출
				var optnAreaText = _common.getOptionNameReturn('optn' , data.optnSetupNmCode );

				$('#rewarehousingText').text(optnAreaText);
				//옵션 노출 관련 추가  20211215 E

