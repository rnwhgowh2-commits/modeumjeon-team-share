		} else if (cartType === "DV") {
			cartType = "D";
			dailyDlvyYn = "Y";
		}

		var returnFlag = true;
		prdtList.forEach(function (item, index, array) {
			item.cartType = cartType; // cartType

			if (item.orderQty == ""){
				returnFlag = false;
			}
			if (item.prdtNo == ""){
