# 무신사 환경변수 양식
#
# 운영 환경에서는 ID/PW 를 환경변수로 두지 않고 Playwright storage_state 로 관리.
# 따라서 본 파일은 "참고용 양식" 이며 실제 .env 에 옮길 항목은 적음.
# 자세한 인증 셋업: login.md 참조.

# ─────────────────────────────────────────
# 무신사 인증 (현재는 storage_state JSON 기반 → ENV 필수 항목 없음)
# ─────────────────────────────────────────
# MUSINSA_DEFAULT_ACCOUNT=영빈            # 명시 시 _get_default_musinsa_account() 우회 (보통 안 씀)
# MUSINSA_HEADLESS=true                    # 명시 시 default true 덮어쓰기 (테스트용 false)

# ─────────────────────────────────────────
# 크롤링 timeout/wait (config.py SOURCING_AUTH 와 동일 — 보통 ENV 안 씀)
# ─────────────────────────────────────────
# MUSINSA_CRAWL_TIMEOUT_MS=25000
# MUSINSA_CSR_WAIT_MS=5000
# MUSINSA_DROPDOWN_WAIT_MS=200
# MUSINSA_STOCK_CAP=10

# ─────────────────────────────────────────
# 정책 (보통 코드/yaml 에서만 변경. ENV 로 override 안 함)
# ─────────────────────────────────────────
# MUSINSA_REVIEW_REWARD_FIXED=500          # DB compute_breakdown 가 처리하므로 크롤러 0
# MUSINSA_CARD_CASHBACK_RATE=0.0273        # 무신사머니 비활성 시 fallback (DB 가 적용)
