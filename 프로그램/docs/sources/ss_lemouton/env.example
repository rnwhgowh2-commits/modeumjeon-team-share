# 스스 르무통 환경변수 양식
#
# 비로그인 + curl_cffi 사용 — 환경변수 필수 항목 없음.

# ─────────────────────────────────────────
# 옵셔널 — 코드 override 필요 시만
# ─────────────────────────────────────────
# SS_LEMOUTON_TIMEOUT=30                    # HTTP timeout
# SS_LEMOUTON_IMPERSONATE=chrome120         # curl_cffi impersonate target

# ─────────────────────────────────────────
# 정책 룰 (DB compute_breakdown 적용, ENV override 없음)
# ─────────────────────────────────────────
# SS_LEMOUTON_NPAY_RATE=0.01                # 네이버페이 적립
# SS_LEMOUTON_CARD_CASHBACK_RATE=0.0273     # 현대카드 캐시백
